# デフォルトで全テキストファイルをLFに正規化
* text=auto eol=lf

# 明示的にLFを強制したい拡張子
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Windows専用ファイルはCRLFのままにする(存在する場合)
*.bat text eol=crlf
*.cmd text eol=crlf

# バイナリファイルは変換対象外(念のため明示)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary